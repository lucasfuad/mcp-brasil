# =============================================================================
# mcp-brasil — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores necessários:
#   cp .env.example .env

# --- Transparência (obrigatória para a feature transparencia) ---
# Cadastre-se gratuitamente em:
# https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=

# --- DataJud (obrigatória para a feature datajud) ---
# Cadastre-se gratuitamente em:
# https://datajud.cnj.jus.br
DATAJUD_API_KEY=

# --- Anúncios Eleitorais (obrigatória para a feature anuncios_eleitorais) ---
# Obtenha um token em:
# https://developers.facebook.com/docs/marketing-api/reference/ad-library/
META_ACCESS_TOKEN=

# --- Autenticação HTTP (opcional) ---
# Quando definido, o server requer Authorization: Bearer <token> nas chamadas HTTP.
# Deixe vazio para uso local/stdio sem autenticação.
MCP_BRASIL_API_TOKEN=

# --- Authentication Strategy ---
# Modo de autenticação do server MCP. Valores aceitos: none | static | oauth
# Auto-detect: se não for setado, usa "static" quando MCP_BRASIL_API_TOKEN está
# definido, senão "none". Mantém backward compat com instalações existentes.
#
# Exemplos:
#   MCP_BRASIL_AUTH_MODE=none     # público (útil para IP allowlist/stdio)
#   MCP_BRASIL_AUTH_MODE=static   # Bearer token estático (requer MCP_BRASIL_API_TOKEN)
#   MCP_BRASIL_AUTH_MODE=oauth    # OAuth 2.0 com DCR (Claude.ai web)
# MCP_BRASIL_AUTH_MODE=

# --- OAuth (apenas quando MCP_BRASIL_AUTH_MODE=oauth) ---
# Provider OAuth. Valores aceitos: azure | google | github | workos
# MCP_BRASIL_OAUTH_PROVIDER=azure

# URL pública do server MCP (ex: https://mcp-brasil.example.com).
# Obrigatório quando AUTH_MODE=oauth. Usado para construir redirect URIs.
# MCP_BRASIL_BASE_URL=

# --- OAuth: Azure (Entra ID) ---
# Criar um App Registration no Portal Azure → Entra ID → App Registrations.
# Redirect URI no App Registration deve ser {MCP_BRASIL_BASE_URL}/auth/callback.
# Ver docs/deploy/azure-oauth.md para o passo a passo completo.
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_REQUIRED_SCOPES=read

# --- OAuth: Google ---
# Criar credentials em https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REQUIRED_SCOPES=openid,email

# --- OAuth: GitHub ---
# Criar OAuth App em https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REQUIRED_SCOPES=

# --- OAuth: WorkOS (AuthKit) ---
# Criar AuthKit app em https://workos.com
# AUTHKIT_DOMAIN=
# AUTHKIT_REQUIRED_SCOPES=

# --- Tool Discovery (opcional — valores padrão já funcionam) ---
# Modos: "bm25" (padrão), "code_mode" (experimental), "none" (sem filtro)
# MCP_BRASIL_TOOL_SEARCH=bm25

# --- LLM Discovery — recomendar_tools / planejar_consulta (opcional) ---
# Necessário para as tools recomendar_tools e planejar_consulta (requer: pip install mcp-brasil[llm])
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- HTTP Client (opcional — valores padrão já funcionam) ---
# MCP_BRASIL_HTTP_TIMEOUT=30.0
# MCP_BRASIL_HTTP_MAX_RETRIES=3
# MCP_BRASIL_HTTP_BACKOFF_BASE=1.0
# MCP_BRASIL_USER_AGENT=mcp-brasil/0.7.2

# --- Azure AI Foundry Agent Service (opcional — ver docs/deploy/foundry-teams.md) ---
# Endpoint do projeto AI Foundry (formato: https://<resource>.services.ai.azure.com/api/projects/<project>)
# PROJECT_ENDPOINT=https://agent-brasil-resource.services.ai.azure.com/api/projects/agent-brasil
# MODEL_DEPLOYMENT=gpt-4o
# MCP_CONNECTION_ID=mcp-brasil
